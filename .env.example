# ─── 3D Print Tracker — environment variables ─────────────────────────────────
# Copy this file to .env for local dev (already gitignored).
# On Render, set these in Dashboard → your service → Environment.

# ── Required for cloud / Render deployment ─────────────────────────────────────

# Supabase Postgres connection string.
# Get it from: Supabase Dashboard → your project → Settings → Database
#   → Connection string → URI  (use the "Session pooler" string, port 5432)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Optional ───────────────────────────────────────────────────────────────────

# Port the API server listens on.
# Render sets PORT automatically; only set this if self-hosting.
# PORT=5000

# Camera relay token — shared secret between this server and the desktop app.
# When set, the desktop Electron app can open a WebSocket to /api/camera-relay
# and stream live JPEG frames from LAN-connected Bambu printers to the cloud,
# making camera feeds viewable from any browser without VPN or port-forwarding.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CAMERA_RELAY_TOKEN=

# ── For the Electron desktop app (pointing at the cloud server) ────────────────
# Set this in a .env file at the project root when building the Electron app.
# The renderer will call this URL instead of Electron IPC for data/settings.
# Leave empty to use Electron IPC (local file storage, default behaviour).
# VITE_API_URL=https://your-app.onrender.com
